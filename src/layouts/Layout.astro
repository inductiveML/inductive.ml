---
import '../styles/v9.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Inductive.ML — Independent AI Research',
	description = 'Independent research on representation, adaptation, and intelligence. An AI research lab studying how learned systems represent, adapt, compress, and generalize.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body style="margin:0; background:#fafaf7;">
		<slot />
	</body>
</html>
